# Optional. Used by GitHub project/profile sync and contribution calendar.
GITHUB_TOKEN=
GH_STATS_TOKEN=

# Optional. Used by Notion article sync.
NOTION_TOKEN=
NOTION_DATABASE_ID=

# Optional. Used by Notion-hosted image caching during sync:notion.
IMAGE_ASSET_PROVIDER=cloudflare-r2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=blog-images
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
R2_OBJECT_PREFIX=notion-images
R2_CACHE_MANIFEST_KEY=notion-images/cache/notion-image-cache.json

# Optional. Used when the shared data config is stored outside the repo root.
BLOG_DATA_CONFIG_PATH=

# Optional. Use "/" for a custom domain or "/repo-name/" for GitHub project pages.
SITE_BASE_PATH=
