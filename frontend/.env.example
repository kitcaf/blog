NOTION_TOKEN=
NOTION_DATABASE_ID=

# Optional when a database has more than one data source.
NOTION_DATA_SOURCE_ID=

# Optional field overrides.
NOTION_TITLE_PROPERTY=Title
NOTION_STATUS_PROPERTY=Status
NOTION_PUBLISHED_STATUS=Published
NOTION_CATEGORY_PROPERTY=Category
NOTION_TAGS_PROPERTY=Tags
NOTION_PUBLISHED_AT_PROPERTY=PublishedAt
NOTION_SLUG_PROPERTY=Slug
NOTION_DESCRIPTION_PROPERTY=Description

# Optional publish defaults.
NOTION_SITE_NAME=kitcaf
NOTION_AUTHOR=xjj
NOTION_DISPLAY_TIME_ZONE=Asia/Shanghai
NOTION_DESCRIPTION_LENGTH=160
NOTION_OUTPUT_PATH=frontend/src/data/posts.json
NOTION_ALLOW_EMPTY_SYNC=false

# The default version uses the current Notion data source API.
NOTION_VERSION=2026-03-11
