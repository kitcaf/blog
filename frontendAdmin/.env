# ─────────────────────────────────────────────────────────
# 前端开发环境变量
#
# 复制此文件为 .env.local 并按需修改（.env.local 不提交到 git）
# ─────────────────────────────────────────────────────────

# ── 开发模式：使用 mock 数据，无需启动 Go 后端 ─────────────
# 设为 true → MockInitializer 激活，数据来自 src/mockData.ts
# 设为 false → 数据来自 VITE_API_BASE_URL 的真实 Go API
VITE_USE_MOCK=true

# ── Go 后端 API 地址 ────────────────────────────────────────
# VITE_USE_MOCK=false 时生效
VITE_API_BASE_URL=http://localhost:8080
