{
  "name": "blog-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "scripts": {
    "dev:frontend": "pnpm --filter frontend dev",
    "pre:frontend": "pnpm --filter frontend preview",
    "build:frontend": "pnpm --filter frontend build",
    "build:blog-data-config": "pnpm --filter @blog/blog-data-config build",
    "sync:notion": "pnpm build:blog-data-config && pnpm --filter @blog/notion-sync sync",
    "sync:github-projects": "pnpm build:blog-data-config && pnpm --filter @blog/github-project-sync sync",
    "sync:github-profile": "pnpm build:blog-data-config && pnpm --filter @blog/github-profile-sync sync",
    "sync:github": "pnpm sync:github-projects && pnpm sync:github-profile",
    "sync:data": "pnpm sync:notion && pnpm sync:github",
    "verify:frontend": "pnpm --filter frontend type-check",
    "build:site": "pnpm sync:data && pnpm verify:frontend && pnpm build:frontend",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
