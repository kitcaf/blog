{
  "name": "@blog/notion-sync",
  "version": "1.0.0",
  "description": "Notion 内容同步与转换模块",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "sync": "pnpm run build && node dist/sync.js",
    "type-check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@blog/blog-data-config": "workspace:*",
    "pinyin-pro": "^3.28.1"
  }
}
